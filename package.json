{
  "name": "price-guard",
  "version": "0.1.0",
  "description": "쇼핑몰 상품 가격을 추적하고 할인/목표가 달성 시 알림을 받는 Chrome 확장프로그램",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:popup": "vite build",
    "build:background": "vite build --config vite.background.config.ts",
    "build:content": "vite build --config vite.content.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{ts,html}\" \"tests/**/*.ts\" \"*.{ts,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.node.json"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "lefthook": "^2.1.5",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
